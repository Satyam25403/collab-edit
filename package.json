{
  "name": "collab-edit",
  "displayName": "Collab Edit",
  "description": "Real-time collaborative coding inside VS Code. Share your workspace with a partner, see live edits, and control file permissions — no account needed.",
  "version": "1.0.0",
  "publisher": "7c93e79d-ff11-602f-97b6-d3c61888cbc2",
  "author": {
    "name": "Satyam Shivam",
    "email": "satyamdk6927@gmail.com"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/collab-edit"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/collab-edit/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/collab-edit#readme",
  "keywords": [
    "collaboration",
    "pair programming",
    "real-time",
    "live share",
    "collab",
    "remote",
    "co-edit",
    "multiplayer"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "collab-explorer",
          "title": "Collab Edit",
          "icon": "$(broadcast)"
        }
      ]
    },
    "views": {
      "collab-explorer": [
        {
          "type": "webview",
          "id": "collab-sidebar",
          "name": "Collab Control Panel"
        }
      ]
    },
    "commands": [
      {
        "command": "collab.createRoom",
        "title": "Collab: Create Room"
      },
      {
        "command": "collab.joinRoom",
        "title": "Collab: Join Room"
      },
      {
        "command": "collab.leaveRoom",
        "title": "Collab: Leave Room"
      }
    ],
    "configuration": {
      "title": "Collab Edit",
      "properties": {
        "collabEdit.serverUrl": {
          "type": "string",
          "default": "wss://YOUR_DEPLOYED_SERVER_URL",
          "description": "WebSocket relay server URL for Collab Edit sessions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.74.0",
    "@types/ws": "^8.5.4",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "ws": "^8.12.0"
  }
}